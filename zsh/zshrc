HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt hist_ignore_dups
setopt autocd
unsetopt beep

alias "$"=""

# Rust package Cache Lock Resolution
# If you encounter "Blocking waiting for file lock on package cache" issue:
# Try removing the package cache file to resolve the problem
# Command: rm -rf ~/.cargo/.package-cache
if [ -d ~/.cargo/.package-cache ]; then
  rm -rf ~/.cargo/.package-cache
fi

export ZENO_GIT_CAT="bat --color=always"
export ZENO_GIT_TREE="eza --tree"

eval "$(sheldon source)"
eval "$(starship init zsh)"
eval "$(direnv hook zsh)"

# Homebrew's zsh completion dir was stripped from fpath in ~/.zprofile so the
# system /etc/zshrc compinit wouldn't flag it as insecure (see zsh/zprofile).
# Re-add it now and rebuild completions ourselves, using -u to skip the
# ownership check on the shared /opt/homebrew. No-op on hosts without Homebrew.
if [[ -n $HOMEBREW_PREFIX && -d $HOMEBREW_PREFIX/share/zsh/site-functions ]]; then
  fpath=($HOMEBREW_PREFIX/share/zsh/site-functions $fpath)
  autoload -Uz compinit && compinit -u
fi

if [[ -n $ZENO_LOADED ]]; then
  bindkey ' '  zeno-auto-snippet
  bindkey '^m' zeno-auto-snippet-and-accept-line
  bindkey '^i' zeno-completion
  bindkey '^x ' zeno-insert-space
  bindkey '^x^m' accept-line
  bindkey '^x^z' zeno-toggle-auto-snippet
  bindkey '^r' zeno-history-selection
  bindkey '^g' zeno-ghq-cd
fi

export PKG_CONFIG_PATH=$PKG_CONFIG_PATH:$HOME/.nix-profile/lib/pkgconfig

