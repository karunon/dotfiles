eval "$(/opt/homebrew/bin/brew shellenv)"

# /opt/homebrew is owned by another admin user on this shared Mac, so its zsh
# completion dir is "not owned by root or me" and trips compinit's security
# check. The system /etc/zshrc runs `compinit` right after this file (before
# ~/.zshrc), so drop the dir from fpath here to avoid the "insecure directories"
# prompt. ~/.zshrc re-adds it and rebuilds completions with `compinit -u`.
if [[ -n $HOMEBREW_PREFIX ]]; then
  fpath=(${fpath:#$HOMEBREW_PREFIX/share/zsh/site-functions})
fi
